<?xml version="1.0"?>
<robot name="car">

    <!-- ===== 运动学车辆模型: 两轮差速 + 高摩擦 ===== -->

    <material name="blue"><color rgba="0.0 0.0 1.0 1.0"/></material>
    <material name="black"><color rgba="0.0 0.0 0.0 1.0"/></material>

    <!-- 车身 -->
    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="50"/>
            <inertia ixx="5" ixy="0" ixz="0" iyy="10" iyz="0" izz="10"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <box size="2.0 1.0 0.4"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <box size="2.0 1.0 0.4"/>
            </geometry>
        </collision>
    </link>

    <!-- 左轮 -->
    <link name="left_wheel">
        <inertial>
            <mass value="2"/>
            <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
        </inertial>
        <visual>
            <geometry>
                <cylinder radius="0.25" length="0.15"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.25" length="0.15"/>
            </geometry>
        </collision>
    </link>

    <!-- 右轮 -->
    <link name="right_wheel">
        <inertial>
            <mass value="2"/>
            <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
        </inertial>
        <visual>
            <geometry>
                <cylinder radius="0.25" length="0.15"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.25" length="0.15"/>
            </geometry>
        </collision>
    </link>

    <!-- 左轮关节 (带阻尼防振荡) -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.6 -0.1" rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <dynamics damping="5.0" friction="0.5"/>
    </joint>

    <!-- 右轮关节 (带阻尼防振荡) -->
    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.6 -0.1" rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <dynamics damping="5.0" friction="0.5"/>
    </joint>

    <!-- 差速驱动: cmd_vel 订阅 + odom 发布 -->
    <gazebo>
        <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
            <updateRate>100.0</updateRate>
            <leftJoint>left_wheel_joint</leftJoint>
            <rightJoint>right_wheel_joint</rightJoint>
            <wheelSeparation>1.2</wheelSeparation>
            <wheelDiameter>0.5</wheelDiameter>
            <torque>10</torque>
            <commandTopic>cmd_vel</commandTopic>
            <odometryTopic>odom</odometryTopic>
            <odometryFrame>odom</odometryFrame>
            <robotBaseFrame>base_link</robotBaseFrame>
            <publishOdomTF>true</publishOdomTF>
        </plugin>
    </gazebo>

    <!-- 轮子高摩擦 (防打滑) -->
    <gazebo reference="left_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>
    <gazebo reference="right_wheel">
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>

</robot>

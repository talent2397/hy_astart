<launch>
    <!-- ============================================================ -->
    <!-- Hybrid A* 全系统启动文件                                      -->
    <!-- 启动顺序: Gazebo → Bridge → Planner → Tracker → RViz        -->
    <!-- ============================================================ -->

    <!-- 地图服务 -->
    <node pkg="map_server" type="map_server" name="map_server"
          args="$(find hybrid_a_star)/maps/map.yaml"/>

    <!-- Gazebo 仿真环境 -->
    <include file="$(find hybrid_a_star)/launch/gazebo_simulation.launch"/>

    <!-- Gazebo Bridge: ROS ↔ SHM 双向转换 -->
    <node pkg="hybrid_a_star" type="run_gazebo_bridge" name="run_gazebo_bridge"
          output="screen" launch-prefix="bash -c 'sleep 3; exec $0 $@'"/>

    <!-- Planner: Hybrid A* 路径规划 (纯 C++ 进程, 不依赖 ROS) -->
    <!-- 通过 IPC SHM 通信, 这里通过 roslaunch 管理进程生命周期 -->
    <node pkg="hybrid_a_star" type="run_planner" name="run_planner"
          output="screen" launch-prefix="bash -c 'sleep 5; exec $0 $@'"/>

    <!-- Tracker: Pure Pursuit / MPC 轨迹跟踪 (纯 C++ 进程) -->
    <node pkg="hybrid_a_star" type="run_tracker" name="run_tracker"
          output="screen" launch-prefix="bash -c 'sleep 5; exec $0 $@'"/>

    <!-- RViz 可视化 -->
    <node pkg="rviz" type="rviz" name="rviz"
          args="-d $(find hybrid_a_star)/rviz/display_hybrid_astar.rviz"/>

    <!-- TF 静态发布 -->
    <node pkg="tf" type="static_transform_publisher" name="world_map_broadcaster"
          args="0 0 0 0 0 0 world map 100"/>
</launch>
